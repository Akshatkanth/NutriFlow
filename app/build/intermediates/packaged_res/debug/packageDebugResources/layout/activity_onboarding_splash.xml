<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_onboarding_gradient">

    <TextView
        android:id="@+id/text_brand"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="88dp"
        android:fontFamily="serif"
        android:includeFontPadding="false"
        android:letterSpacing="0"
        android:text="@string/onboarding_brand_name"
        android:textColor="@color/text_primary"
        android:textSize="66sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.progressindicator.CircularProgressIndicator
        android:id="@+id/tap_ring"
        android:layout_width="78dp"
        android:layout_height="78dp"
        android:indeterminate="true"
        app:indicatorColor="@color/onboarding_cta_green"
        app:indicatorSize="78dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.498"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/text_brand"
        app:layout_constraintVertical_bias="0.575"
        app:trackColor="#F0F0F0"
        app:trackThickness="3dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
